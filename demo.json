{
   "general": {
      "demo_title": "Image Retrieval using Scene Graphs",
      "description": "Build a scene graph query by selecting objects and relationships, then retrieve the most relevant images from the dataset using a CRF-based scoring pipeline.",
      "requirements": "docker",
      "timeout": "3600",
      "custom_js": "custom.js"
   },
   "build": {
      "url": "git@github.com:titiuo/RR-Image-Retrieval-using-Scene-Graphs.git",
      "rev": "origin/main",
      "dockerfile": ".ipol/Dockerfile"
   },
   "archive": {
      "files": {
         "results.html": "results gallery"
      },
      "params": [
         "objects",
         "relationships"
      ],
      "enable_reconstruct": "true",
      "info": {
         "run_time": "run time"
      }
   },
   "inputs": [],
   "params": [
      {
         "id": "objects",
         "type": "text",
         "label": "Selected objects",
         "comments": "Filled automatically by the query builder above.",
         "values": { "default": "" }
      },
      {
         "id": "relationships",
         "type": "text",
         "label": "Selected relationships",
         "comments": "Filled automatically by the query builder above. Format: subj_idx predicate obj_idx (e.g. 0 on 1).",
         "values": { "default": "" }
      }
   ],
   "results": [
      {
         "type": "html_file",
         "label": "Retrieval Results",
         "contents": "results.html"
      }
   ],
   "run": "python3 $bin/main.py \"$objects\" \"$relationships\""
}